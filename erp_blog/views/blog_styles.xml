<odoo>
    <template id="blog_post_video">
        <a t-attf-href="#{record.page_url}" class="text-decoration-none d-block">
            <div class="media_iframe_video">
                <div class="css_editable_mode_display" data-bs-original-title="blog_video" title=""/>
                <div class="media_iframe_video_size"/>
                <t t-raw="record.iframe"/>
            </div>
            <h4 class="mt32">
                <font style="font-size: 24px;" class="text-o-color-1">
                    <t t-esc="record.name"/>
                </font>
            </h4>
            <p class="mt16 text-justify" style="font-size: 16px;">
                <t t-raw="record.subtitle"/>
            </p>
        </a>

    </template>
    <template id="blog_list_publications">
        <div class="row blog-item align-items-center">
            <div class="col-md-2 blog-date">
                <t t-if="record.publication_date">
                    <t t-esc="record.publication_date.year"/>
                </t>
                <t t-else="">
                    <t t-esc="record.publication_date"/>
                </t>

            </div>
            <div class="col-md-8 blog-title">
                <t t-esc="record.name"/>
                <p style="font-size: 14px;" class="text-justify mt-2">
                    <t t-raw="record.subtitle"/>
                </p>

            </div>
            <div class="col-md-2 text-md-end mt-3 mt-md-0">
                <a t-attf-href="#{record.page_url}" class="view-link">
                    View paper →
                </a>
            </div>
        </div>


    </template>
    <template id="blog_card_download">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col">
                    <div class="card shadow-sm border-0">
                        <div class="mt-1">
                            <img t-attf-src="/web/image/blog.post/#{record.id}/erp_image"
                                 class="card-img-top img-fluid"/>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title text-danger">
                                <t t-esc="record.name"/>
                            </h5>

                            <p class="card-text text-muted small">
                                <t t-esc="record.subtitle"/>
                            </p>
                            <t t-if="record.use_form">
                                 <a t-attf-href="#downloadModal-#{record.id}" data-bs-toggle="modal">
                                    Download the Buyer’s Guide
                                </a>
                            </t>
                            <t t-else="">
                                <a t-attf-href="/web/content/#{record.download_attachment.id}?download=True" >
                                    Download the Buyer’s Guide
                                </a>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div t-if='record.use_form' class="modal fade" t-attf-id="downloadModal-#{record.id}" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Download the Buyer’s Guide</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"/>
                    </div>

                    <div class="modal-body">

                        <section class="s_website_form pt16 pb16">
                            <div class="o_container_small">

                                <form action="/website/form/"
                                      method="post"
                                      enctype="multipart/form-data"
                                      class="o_mark_required"
                                      data-model_name="crm.lead"
                                      data-success-mode="redirect"
                                      t-attf-data-success-page="/web/content/#{record.download_attachment.id}?download=True"
                                >

                                    <div class="row">

                                        <div class="col-12 mb-3">
                                            <label>Name *</label>
                                            <input class="form-control"
                                                   type="text"
                                                   name="name"
                                                   required="1"/>
                                        </div>

                                        <div class="col-12 mb-3">
                                            <label>Your Email *</label>
                                            <input class="form-control"
                                                   type="email"
                                                   name="email_from"
                                                   required="1"/>
                                        </div>

                                        <div class="col-12 mb-3">
                                            <label>Company *</label>
                                            <input class="form-control"
                                                   type="text"
                                                   name="Company"
                                                   required="1"/>
                                        </div>

                                        <div class="col-12">
                                            <button type="submit" data-bs-dismiss="modal"
                                                    class="btn btn-primary w-100">
                                                Submit
                                            </button>
                                        </div>

                                    </div>

                                </form>

                            </div>
                        </section>

                    </div>

                </div>
            </div>
        </div>


    </template>
</odoo>